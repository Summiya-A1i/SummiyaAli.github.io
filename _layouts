                <a href="{{ site.baseurl }}/blog5">5. Story Five ✅</a>
                <a href="{{ site.baseurl }}/blog6">6. Story Six 🎓</a>
            </div>
        </div>

        <!-- SEMESTER 2 DROPDOWN -->
        <div class="dropdown">
            <a href="{{ site.baseurl }}/semester2">Semester 2 ✨</a>
            <div class="dropdown-content">
                <a href="{{ site.baseurl }}/week1">Week 1 Reflection ✍️</a>
                <a href="{{ site.baseurl }}/week2">Week 2 Reflection ⚙️</a>
            </div>
        </div>

        <a href="{{ site.baseurl }}/blog">All Posts 📝</a>
    </div>
</nav>

    <div class="hero">
        <h1>Summiya Tabbassum Ali</h1>
        <p>Computer Engineering | UET Lahore</p>

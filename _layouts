<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Summiya's Journey | {{ page.title }}</title>
    <style>
        :root {
            --pink: #ff69b4; 
            --black: #0d0d0d;
            --surface: #1a1a1a;
        }

        body {
            background-color: var(--black);
            color: #f0f0f0;
            font-family: 'Segoe UI', sans-serif;
            margin: 0; padding: 0;
        }

        /* 🎀 STYLISH NAVBAR */
        .navbar {
            background: rgba(13, 13, 13, 0.95);
            padding: 15px 8%;
            display: flex; justify-content: space-between; align-items: center;
            border-bottom: 2px solid var(--pink);
            position: sticky; top: 0; z-index: 1000;
        }

        .navbar .logo { font-size: 1.4rem; font-weight: bold; color: var(--pink); text-shadow: 0 0 10px var(--pink); }
        .navbar a { color: white; text-decoration: none; margin-left: 20px; font-weight: 500; font-size: 0.9rem; }
        .navbar a:hover { color: var(--pink); }

        /* ✨ COVER IMAGE (HERO) */
        .hero {
            height: 400px;
            background: linear-gradient(rgba(0,0,0,0.75), rgba(0,0,0,0.75)), 
                        url('https://i.pinimg.com/1200x/52/88/e9/5288e904462b08a65196179399da57e7.jpg'); /* <--- Put your link here! */
            background-size: cover; background-position: center;
            display: flex; flex-direction: column; justify-content: center; align-items: center;
            text-align: center; border-bottom: 3px solid var(--pink);
        }

        .hero h1 { font-size: 3.5rem; color: var(--pink); margin-bottom: 10px; text-shadow: 2px 2px 15px #000; }
        .hero p { font-size: 1.1rem; color: #fff; text-transform: uppercase; letter-spacing: 3px; }

        /* 🆔 CONTACT BADGE */
        .badge {
            background: rgba(255, 105, 180, 0.1);
            border: 1px solid var(--pink);
            padding: 10px 20px; border-radius: 30px;
            margin-top: 20px; color: white; font-weight: bold; font-size: 0.9rem;
        }

        /* 🌸 CONTAINER */
        .container {
            max-width: 900px; margin: 40px auto; padding: 40px;
            background: var(--surface); border-radius: 15px;
            border: 1px solid #333; box-shadow: 0 15px 40px rgba(0,0,0,0.6);
        }

        h1, h2, h3 { color: var(--pink); }
        table { width: 100%; border-collapse: collapse; margin: 20px 0; border-radius: 8px; overflow: hidden; }
        th, td { border: 1px solid #333; padding: 12px; text-align: left; }
        th { background-color: var(--pink); color: black; font-weight: bold; }
        blockquote { border-left: 5px solid var(--pink); padding: 15px; background: #111; font-style: italic; border-radius: 0 10px 10px 0; }

    </style>
/* DROPDOWN STYLING 🎀 */
.dropdown { position: relative; display: inline-block; }

.dropdown-content {
    display: none;
    position: absolute;
    background-color: #1a1a1a;
    min-width: 220px;
    box-shadow: 0px 8px 16px rgba(255,105,180,0.4);
    z-index: 1001;
    border: 1px solid var(--pink);
    border-radius: 8px;
    top: 100%; /* Appears right under the bar */
}

.dropdown-content a {
    color: white !important;
    padding: 12px 16px;
    text-decoration: none;
    display: block;
    font-size: 0.85rem;
    border-bottom: 1px solid #333;
    margin: 0 !important; /* Reset margins for dropdown links */
}

.dropdown-content a:hover { background-color: var(--pink); color: black !important; }
.dropdown:hover .dropdown-content { display: block; }
    </style>
    <nav class="navbar">
    <div class="logo">Summiya.Codes 🎀</div>
